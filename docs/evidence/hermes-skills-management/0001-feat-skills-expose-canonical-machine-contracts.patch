+def _canonical_installed_contract(identifier_filter: Optional[str] = None) -> dict:
+    """Build installed state from profile files plus the canonical Hub lock."""
+    from agent.skill_utils import (
+        get_disabled_skill_names, get_external_skills_dirs, iter_skill_index_files,
+        parse_frontmatter,
+    )
+    from hermes_constants import get_hermes_home
+    from tools.skills_hub import HubLockFile
+    from tools.skills_sync import _read_manifest
+
+    lock_entries = HubLockFile().list_installed()
+    by_name = {entry["name"]: entry for entry in lock_entries}
+    builtin_names = set(_read_manifest())
+    target_lock_entries = (
+        [entry for entry in lock_entries if entry.get("identifier") == identifier_filter]
+        if identifier_filter else []
+    )
+    target_name = (
+        str(target_lock_entries[0]["name"])
+        if target_lock_entries else (identifier_filter.rsplit("/", 1)[-1] if identifier_filter else None)
+    )
+    disabled = get_disabled_skill_names()
+    active_skills_root = get_hermes_home() / "skills"
+    roots = [active_skills_root, *get_external_skills_dirs()]
+    matches: list[dict] = []
+    seen_paths: set[str] = set()
+    for root in roots:
+        if not root.exists():
+            continue
+        for skill_md in iter_skill_index_files(root, "SKILL.md"):
+            canonical_path = str(skill_md.resolve())
+            if canonical_path in seen_paths:
+                continue
+            seen_paths.add(canonical_path)
+            try:
+                frontmatter, _body = parse_frontmatter(skill_md.read_text(encoding="utf-8"))
+            except (OSError, UnicodeDecodeError, ValueError):
+                continue
+            name = str(frontmatter.get("name") or skill_md.parent.name)
+            entry = None
+            candidate_entry = by_name.get(name)
+            if candidate_entry is not None:
+                try:
+                    installed_rel = skill_md.parent.resolve().relative_to(
+                        active_skills_root.resolve()
+                    ).as_posix()
+                except ValueError:
+                    installed_rel = None
+                if installed_rel == candidate_entry.get("install_path"):
+                    entry = candidate_entry
+            hub_identifier = entry.get("identifier") if entry else None
+            if identifier_filter is not None and hub_identifier != identifier_filter and name != target_name:
+                continue
+            is_builtin = entry is None and name in builtin_names
+            source = str(entry.get("source")) if entry else ("builtin" if is_builtin else "local")
+            matches.append({
+                "enabled": name not in disabled,
+                "identifier": hub_identifier,
+                "name": name,
+                "origin": "hub" if entry else ("builtin" if is_builtin else "local"),
+                "source": source,
+                "trust": "official" if source == "official" else (
+                    str(entry.get("trust_level", "community")) if entry else ("builtin" if is_builtin else "local")
+                ),
+            })
+
+    # A lock entry without a corresponding SKILL.md is observable corruption,
+    # not installed success. Include it as a non-present diagnostic match only
+    # when the exact identifier was requested.
+    if identifier_filter is not None and not matches:
+        stale = [e for e in lock_entries if e.get("identifier") == identifier_filter]
+        for entry in stale:
+            matches.append({
+                "enabled": False,
+                "identifier": entry.get("identifier"),
+                "name": entry.get("name"),
+                "origin": "hub-lock-only",
+                "source": entry.get("source"),
+                "trust": "official" if entry.get("source") == "official" else entry.get("trust_level"),
+            })
+
+    matches.sort(key=lambda item: (
+        str(item.get("name")), str(item.get("identifier")), str(item.get("origin"))
+    ))
+    exact_present = [
+        item for item in matches
+        if item["origin"] != "hub-lock-only"
+        and (identifier_filter is None or item["identifier"] == identifier_filter)
+    ]
+    same_names: dict[str, int] = {}
+    for item in matches:
+        if item["origin"] == "hub-lock-only":
+            continue
+        same_names[item["name"]] = same_names.get(item["name"], 0) + 1
+    return {
+        "contract": "hermes.skills.installed-state",
+        "exact_match_count": len(exact_present),
+        "matches": matches,
+        "profile": _active_profile_name(),
+        "schema_version": _MACHINE_CONTRACT_VERSION,
+        "same_name_collision_count": sum(max(0, count - 1) for count in same_names.values()),
+    }
+
+
