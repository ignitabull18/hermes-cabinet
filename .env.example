# Optional: set a password to protect the UI (leave empty for no auth).
# The auth cookie is PBKDF2(password, per-install salt). Changing the password
# (or salt/iterations) logs everyone out once.
KB_PASSWORD=

# Auth hardening (all optional):
# CABINET_AUTH_SALT — per-install salt for the auth token. Auto-generated into
#   .cabinet.env on first run; set it here only to pin a specific value.
#   Changing or clearing it forces a one-time re-login.
# CABINET_LOGIN_PBKDF2_ITERS — KDF cost (default 600000). Lower only for
#   constrained hardware; values below ~300000 are discouraged.
# Login rate limiting (per-process, in-memory):
# CABINET_LOGIN_MAX_ATTEMPTS=10      # failed attempts per client before lockout
# CABINET_LOGIN_WINDOW_MS=900000     # counting window (15 min)
# CABINET_LOGIN_LOCKOUT_MS=900000    # lockout duration once tripped (15 min)
# CABINET_LOGIN_GLOBAL_MAX=60        # global failed-attempt ceiling per window

# Optional: domain for the app
DOMAIN=localhost

# Optional: override the shared data directory.
# Defaults to ./data for source installs, or a managed app-data path in Electron.
# CABINET_DATA_DIR=

# Optional: release manifest URL for update checks.
# CABINET_RELEASE_MANIFEST_URL=https://github.com/cabinetai/cabinet/releases/latest/download/cabinet-release.json

# Optional: GitHub personal access token. Raises the registry API limit
# from 60/hr (unauthenticated) to 5000/hr. Any fine-grained token with
# public-repo read access is enough.
# GITHUB_TOKEN=

# Optional: override runtime ports and origins when embedding Cabinet in Electron.
# CABINET_APP_PORT=3000
# CABINET_DAEMON_PORT=3001
# CABINET_APP_ORIGIN=http://127.0.0.1:3000
# CABINET_PUBLIC_DAEMON_ORIGIN=ws://127.0.0.1:3001

# Optional: select the agent runtime implementation. Defaults to "cabinet".
# Set to "hermes" for the Hermes-first product mode. This is server-only;
# do not rename it with a NEXT_PUBLIC_ prefix. Keep real credentials only in
# ignored local environment files or the supervised owner-only environment file.
# CABINET_RUNTIME_MODE=hermes

# Native Hermes conversation execution. These values are read only by the
# Cabinet server. Never expose them through NEXT_PUBLIC_* variables.
# CABINET_HERMES_EXECUTION_CLI_PATH=/absolute/path/to/acp-capable-hermes
# CABINET_HERMES_EXECUTION_NO_TOOLS=true
# HERMES_HOME=/absolute/path/to/hermes-home
# OLLAMA_API_KEY=replace-with-the-server-only-provider-key
# CABINET_HERMES_PROFILE=operator-os
# CABINET_HERMES_TIMEOUT_MS=3000

# Optional Hermes service bridges. Configure only the Agent API, Management,
# or Gateway-backed read, run, management, and diagnostic features you use.
# Native ACP conversations do not use these endpoints.
# CABINET_HERMES_API_URL=http://127.0.0.1:8642
# CABINET_HERMES_API_KEY=replace-with-the-Hermes-API-server-key
# CABINET_HERMES_MANAGEMENT_URL=http://127.0.0.1:56314
# CABINET_HERMES_MANAGEMENT_TOKEN=replace-with-the-server-only-management-token
# CABINET_HERMES_GATEWAY_URL=http://127.0.0.1:8645
# CABINET_HERMES_GATEWAY_TOKEN=replace-with-the-server-only-WS-token

# Optional fixed Hermes executable for durable Skills install/update/remove.
# Browser input can never change this server-only path.
# CABINET_HERMES_CLI_PATH=/Users/you/.hermes/hermes-agent-cli-pr13/venv/bin/hermes

# Optional and disabled by default. This enables only implemented governed
# intervention routes; fresh authority, typed confirmation, and idempotency
# requirements still apply.
# CABINET_HERMES_INTERVENTIONS_ENABLED=false
