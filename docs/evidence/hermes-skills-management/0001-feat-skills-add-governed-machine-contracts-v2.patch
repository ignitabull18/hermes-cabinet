+    }
+    (profile_home / "skills" / ".hub" / "lock.json").write_text(
+        json.dumps(lock), encoding="utf-8"
+    )
+    with pytest.raises(SystemExit):
+        do_list(as_json=True, identifier_filter=IDENTIFIER)
+    payload = _payload(capsys)
+    assert "stale_lock_only:stale-rule" in payload["ambiguities"]
+
+
+def test_canonical_rejects_lock_path_name_mismatch(profile_home, capsys):
+    skill_dir = profile_home / "skills" / "communication" / "one-three-one-rule"
