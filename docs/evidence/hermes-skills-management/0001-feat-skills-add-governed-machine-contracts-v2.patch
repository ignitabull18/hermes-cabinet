+def _canonical_installed_contract(identifier_filter: Optional[str] = None) -> dict:
+    """Build ambiguity-safe installed state from profile files and Hub lock."""
+    from agent.skill_utils import (
+        get_disabled_skill_names, get_external_skills_dirs, iter_skill_index_files,
+        parse_frontmatter,
+    )
+    from hermes_constants import get_hermes_home
+    from tools.skills_hub import (
+        HubLockFile, _normalize_lock_install_path, _validate_skill_name,
+    )
+    from tools.skills_sync import _read_manifest
+
+    if identifier_filter is not None and (
+        not isinstance(identifier_filter, str)
+        or not identifier_filter.startswith("official/")
+    ):
+        _machine_fail(
+            "hermes.skills.installed-state", "exact_official_identifier_required"
+        )
+
+    active_skills_root = get_hermes_home() / "skills"
+    ambiguities: list[str] = []
+
+    lock_path = HubLockFile().path
+    lock_entries: list[dict] = []
+    if lock_path.exists():
+        duplicate_keys: list[str] = []
+
+        def reject_duplicate_keys(pairs):
+            value = {}
+            for key, item in pairs:
+                if key in value:
+                    duplicate_keys.append(str(key))
+                else:
+                    value[key] = item
+            return value
+
+        try:
+            lock_data = json.loads(
+                lock_path.read_text(encoding="utf-8"),
+                object_pairs_hook=reject_duplicate_keys,
+            )
+        except (OSError, UnicodeDecodeError, json.JSONDecodeError):
+            _machine_fail(
+                "hermes.skills.installed-state", "invalid_lock_contract"
+            )
+        if duplicate_keys:
+            ambiguities.extend(
+                f"duplicate_lock_key:{key}" for key in duplicate_keys
+            )
+        installed_data = (
+            lock_data.get("installed") if isinstance(lock_data, dict) else None
+        )
+        if (
+            not isinstance(lock_data, dict)
+            or lock_data.get("version") != 1
+            or not isinstance(installed_data, dict)
+        ):
+            _machine_fail(
+                "hermes.skills.installed-state", "invalid_lock_contract"
+            )
+        for raw_name, raw_entry in installed_data.items():
+            if not isinstance(raw_name, str) or not isinstance(raw_entry, dict):
+                _machine_fail(
+                    "hermes.skills.installed-state", "invalid_lock_contract"
+                )
+            try:
+                name = _validate_skill_name(raw_name)
+                install_path = _normalize_lock_install_path(
+                    raw_entry.get("install_path", ""), name
+                )
+            except ValueError:
+                ambiguities.append(f"path_mismatch:{raw_name}")
+                continue
+            identifier = raw_entry.get("identifier")
+            source = raw_entry.get("source")
+            native_trust = raw_entry.get("trust_level")
+            if not all(
+                isinstance(value, str) and value
+                for value in (identifier, source, native_trust)
+            ):
+                _machine_fail(
+                    "hermes.skills.installed-state", "invalid_lock_contract"
+                )
+            lock_entries.append({
+                **raw_entry,
+                "identifier": identifier,
+                "install_path": install_path,
+                "name": name,
+                "source": source,
+                "trust_level": native_trust,
+            })
+
+    for field in ("identifier", "install_path"):
+        values: dict[str, list[str]] = {}
+        for entry in lock_entries:
+            values.setdefault(str(entry[field]), []).append(str(entry["name"]))
+        for value, names in values.items():
+            if len(names) > 1:
+                ambiguities.append(
+                    f"duplicate_{field}:{value}:{','.join(sorted(names))}"
+                )
+
+    discovered: list[dict] = []
+    canonical_paths: dict[str, int] = {}
+    roots = [active_skills_root, *get_external_skills_dirs()]
+    for root in roots:
+        if not root.exists():
+            continue
+        for skill_md in iter_skill_index_files(root, "SKILL.md"):
+            canonical_path = str(skill_md.resolve())
+            canonical_paths[canonical_path] = canonical_paths.get(canonical_path, 0) + 1
+            try:
+                frontmatter, _body = parse_frontmatter(skill_md.read_text(encoding="utf-8"))
+            except (OSError, UnicodeDecodeError, ValueError):
+                ambiguities.append(f"unreadable_skill:{canonical_path}")
+                continue
+            name = str(frontmatter.get("name") or skill_md.parent.name)
+            try:
+                _validate_skill_name(name)
+            except ValueError:
+                ambiguities.append(f"invalid_skill_name:{canonical_path}")
+                continue
+            try:
+                installed_rel = skill_md.parent.resolve().relative_to(
+                    active_skills_root.resolve()
+                ).as_posix()
+            except ValueError:
+                installed_rel = None
+            discovered.append({
+                "canonical_path": canonical_path,
+                "install_path": installed_rel,
+                "name": name,
+            })
+
+    for canonical_path, count in canonical_paths.items():
+        if count > 1:
+            ambiguities.append(f"duplicate_install_path:{canonical_path}")
+
+    names: dict[str, list[str]] = {}
+    for skill in discovered:
+        names.setdefault(skill["name"], []).append(skill["canonical_path"])
+    for name, paths in names.items():
+        if len(paths) > 1:
+            ambiguities.append(
+                f"duplicate_name:{name}:{','.join(sorted(paths))}"
+            )
+
+    lock_by_path: dict[str, dict] = {}
+    for entry in lock_entries:
+        install_path = str(entry["install_path"])
+        matching = [
+            skill for skill in discovered
+            if skill["install_path"] == install_path
+        ]
+        resolved = active_skills_root.joinpath(*install_path.split("/"))
+        if any(
+            candidate.is_symlink()
+            for candidate in [active_skills_root, resolved, *resolved.parents]
+            if candidate == active_skills_root
+            or active_skills_root in candidate.parents
+        ):
+            ambiguities.append(f"path_mismatch:{entry['name']}")
+            continue
+        if len(matching) != 1 or not resolved.joinpath("SKILL.md").is_file():
+            ambiguities.append(f"stale_lock_only:{entry['name']}")
+            continue
+        if matching[0]["name"] != entry["name"]:
+            ambiguities.append(f"path_mismatch:{entry['name']}")
+            continue
+        if install_path in lock_by_path:
+            ambiguities.append(f"multiple_lock_records:{install_path}")
+            continue
+        lock_by_path[install_path] = entry
+
+    if ambiguities:
+        bounded = sorted(set(ambiguities))[:32]
+        _machine_fail(
+            "hermes.skills.installed-state",
+            "canonical_ambiguity",
+            ambiguities=bounded,
+            ambiguity_count=len(set(ambiguities)),
+            profile=_active_profile_name(),
+        )
+
+    builtin_names = set(_read_manifest())
+    disabled = get_disabled_skill_names()
+    matches: list[dict] = []
+    for skill in discovered:
+        entry = (
+            lock_by_path.get(skill["install_path"])
+            if skill["install_path"] is not None else None
+        )
+        is_builtin = entry is None and skill["name"] in builtin_names
+        identifier = str(entry["identifier"]) if entry else None
+        source = str(entry["source"]) if entry else (
+            "builtin" if is_builtin else "local"
+        )
+        native_trust = str(entry["trust_level"]) if entry else (
+            "builtin" if is_builtin else "local"
+        )
+        match = {
+            "enabled": skill["name"] not in disabled,
+            "identifier": identifier,
+            "install_path": skill["install_path"],
+            "installed": True,
+            "name": skill["name"],
+            "origin": "hub" if entry else ("builtin" if is_builtin else "local"),
+            **_authority_fields(source, native_trust, identifier),
+        }
+        matches.append(match)
+
+    matches.sort(key=lambda item: (
+        str(item.get("name")), str(item.get("identifier")),
+        str(item.get("install_path")), str(item.get("origin")),
+    ))
+    target_name = (
+        identifier_filter.rsplit("/", 1)[-1] if identifier_filter else None
+    )
+    if identifier_filter is not None:
+        matches = [
+            item for item in matches
+            if item["identifier"] == identifier_filter
+            or item["name"] == target_name
+        ]
+    exact_present = [
+        item for item in matches
+        if item["installed"] is True
+        and item["origin"] == "hub"
+        and (identifier_filter is None or item["identifier"] == identifier_filter)
+    ]
+    return {
+        "ambiguity_count": 0,
+        "contract": "hermes.skills.installed-state",
+        "exact_match_count": len(exact_present),
+        "matches": matches,
+        "profile": _active_profile_name(),
+        "schema_version": _MACHINE_CONTRACT_VERSION,
+        "same_name_collision_count": 0,
+    }
+
+
