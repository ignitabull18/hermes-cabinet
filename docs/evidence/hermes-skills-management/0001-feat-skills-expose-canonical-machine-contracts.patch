     When ``deep=True``, also runs an opt-in AST-level diagnostic on Python
@@ -1090,12 +1282,47 @@ def do_audit(name: Optional[str] = None, console: Optional[Console] = None,
 
     c = console or _console
 
+    if as_json:
+        if not name or "/" not in name or deep:
+            _machine_fail("hermes.skills.audit", "exact_identifier_required")
+        meta, bundle = _resolve_official_candidate(name)
+        import tempfile
+        from tools.skills_guard import scan_skill
+        from tools.skills_hub import _validate_bundle_rel_path, _validate_skill_name
+
+        with tempfile.TemporaryDirectory(prefix="hermes-skill-audit-") as tmp:
+            quarantine_path = Path(tmp) / _validate_skill_name(bundle.name)
+            quarantine_path.mkdir()
+            for rel_path, content in bundle.files.items():
+                safe_rel_path = _validate_bundle_rel_path(rel_path)
+                target = quarantine_path.joinpath(*safe_rel_path.split("/"))
+                target.parent.mkdir(parents=True, exist_ok=True)
+                if isinstance(content, bytes):
+                    target.write_bytes(content)
+                else:
+                    target.write_text(content, encoding="utf-8")
+            result = scan_skill(quarantine_path, source="official")
+        _machine_json({
+            "contract": "hermes.skills.audit",
+            "finding_count": len(result.findings),
+            "identifier": meta.identifier,
+            "local_fulfillment": True,
+            "name": meta.name,
+            "official": True,
+            "prerequisite_classes": _candidate_prerequisite_classes(bundle),
+            "profile": _active_profile_name(),
+            "public": True,
+            "schema_version": _MACHINE_CONTRACT_VERSION,
+            "source": "official",
+            "trust": "official",
+            "verdict": result.verdict,
+        })
+        return
+
     # A full Hub identifier is an explicit read-only candidate audit. Resolve
