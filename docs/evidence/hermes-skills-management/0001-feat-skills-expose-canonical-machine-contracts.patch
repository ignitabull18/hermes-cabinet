+_MACHINE_CONTRACT_VERSION = 1
+
+
+def _machine_json(payload: dict) -> None:
+    """Write exactly one stable JSON object without Rich rendering."""
+    print(json.dumps(payload, ensure_ascii=False, sort_keys=True, separators=(",", ":")))
+
+
+def _machine_fail(contract: str, code: str) -> None:
+    _machine_json({
+        "contract": contract,
+        "error": code,
+        "schema_version": _MACHINE_CONTRACT_VERSION,
+    })
+    raise SystemExit(1)
+
+
+def _active_profile_name() -> str:
+    from hermes_cli.profiles import get_active_profile_name
+
+    return get_active_profile_name()
+
+
+def _candidate_prerequisite_classes(bundle) -> list[str]:
+    """Classify prerequisites without returning SKILL.md content or values."""
+    from agent.skill_utils import parse_frontmatter
+
+    raw = bundle.files.get("SKILL.md", b"")
+    if isinstance(raw, bytes):
+        raw = raw.decode("utf-8", errors="strict")
+    frontmatter, _body = parse_frontmatter(raw)
+    classes: set[str] = set()
+    if frontmatter.get("platforms"):
+        classes.add("platform")
+    requirements = frontmatter.get("requirements")
+    if isinstance(requirements, dict):
+        aliases = {
+            "bins": "command", "commands": "command", "env": "environment",
+            "environment": "environment", "credentials": "credential",
+            "account": "account", "network": "network",
+        }
+        for key, value in requirements.items():
+            if value and str(key) in aliases:
+                classes.add(aliases[str(key)])
+    return sorted(classes)
+
+
+def _resolve_official_candidate(identifier: str):
+    from tools.skills_hub import OptionalSkillSource
+
+    source = OptionalSkillSource()
+    meta = source.inspect(identifier)
+    bundle = source.fetch(identifier)
+    if (
+        meta is None or bundle is None
+        or meta.identifier != identifier or bundle.identifier != identifier
+        or meta.source != "official" or bundle.source != "official"
+    ):
+        _machine_fail("hermes.skills.candidate", "official_candidate_not_found")
+    return meta, bundle
+
 
