@@ -0,0 +1,283 @@
+from __future__ import annotations
+
+import json
+from pathlib import Path
+
+import pytest
+
+from hermes_cli.secret_source_startup import (
+    SKIP_ENV_NAME, SKIP_ENV_VALUE, validate_requested_skip,
+)
+from hermes_cli.skills_hub import do_audit, do_inspect, do_list, do_uninstall
+from tools.skills_hub import HubLockFile
+
+
+IDENTIFIER = "official/communication/one-three-one-rule"
+
+
+@pytest.fixture()
+def profile_home(tmp_path, monkeypatch):
+    root = tmp_path / ".hermes"
+    home = root / "profiles" / "operator-os"
+    home.mkdir(parents=True)
+    monkeypatch.setenv("HOME", str(tmp_path))
+    monkeypatch.setenv("HERMES_HOME", str(home))
+    return home
+
+
+def _payload(capsys):
+    output = capsys.readouterr().out
+    assert output.count("\n") == 1
+    return json.loads(output)
+
+
+def test_candidate_inspect_is_bounded_deterministic_and_content_free(profile_home, capsys):
+    outputs = []
+    for _ in range(50):
+        do_inspect(IDENTIFIER, as_json=True)
+        outputs.append(capsys.readouterr().out)
+    first = outputs[0]
+    assert outputs == [first] * 50
+    payload = json.loads(first)
+    assert payload == {
+        "contract": "hermes.skills.candidate",
+        "authority_class": "official_public",
+        "identifier": IDENTIFIER,
+        "local_fulfillment": True,
+        "name": "one-three-one-rule",
+        "native_trust": "builtin",
+        "official": True,
+        "prerequisite_classes": ["platform"],
+        "profile": "operator-os",
+        "public": True,
+        "schema_version": 2,
+        "source": "official",
+    }
+    assert "description" not in payload
+    assert "content" not in payload
+
+
+def test_candidate_audit_is_read_only_safe_and_zero_findings(profile_home, capsys):
+    before = sorted(str(path.relative_to(profile_home)) for path in profile_home.rglob("*"))
+    payloads = []
+    for _ in range(50):
+        do_audit(IDENTIFIER, as_json=True)
+        payloads.append(_payload(capsys))
+    payload = payloads[0]
+    assert payloads == [payload] * 50
+    after = sorted(str(path.relative_to(profile_home)) for path in profile_home.rglob("*"))
+    assert before == after
+    assert payload["contract"] == "hermes.skills.audit"
+    assert payload["identifier"] == IDENTIFIER
+    assert payload["profile"] == "operator-os"
+    assert payload["verdict"] == "safe"
+    assert payload["finding_count"] == 0
+
+
+def test_canonical_absence_is_exact_and_does_not_create_hub_state(profile_home, capsys):
+    payloads = []
+    for _ in range(100):
+        do_list(as_json=True, identifier_filter=IDENTIFIER)
+        payloads.append(_payload(capsys))
+    payload = payloads[0]
+    assert payloads == [payload] * 100
+    assert payload == {
+        "ambiguity_count": 0,
+        "contract": "hermes.skills.installed-state",
+        "exact_match_count": 0,
+        "matches": [],
+        "profile": "operator-os",
+        "same_name_collision_count": 0,
+        "schema_version": 2,
+    }
+    assert not (profile_home / "skills" / ".hub").exists()
+
+
+def test_canonical_exact_official_install_and_collision(profile_home, tmp_path, monkeypatch, capsys):
+    skill_dir = profile_home / "skills" / "communication" / "one-three-one-rule"
+    skill_dir.mkdir(parents=True)
+    (skill_dir / "SKILL.md").write_text("---\nname: one-three-one-rule\n---\n", encoding="utf-8")
+    lock_path = profile_home / "skills" / ".hub" / "lock.json"
+    lock = HubLockFile(lock_path)
+    lock.record_install(
+        name="one-three-one-rule", source="official", identifier=IDENTIFIER,
+        trust_level="builtin", scan_verdict="safe", skill_hash="abc",
+        install_path="communication/one-three-one-rule", files=["SKILL.md"],
+    )
+
+    do_list(as_json=True, identifier_filter=IDENTIFIER)
+    payload = _payload(capsys)
+    assert payload["exact_match_count"] == 1
+    assert payload["same_name_collision_count"] == 0
+    assert payload["matches"][0]["source"] == "official"
+    assert payload["matches"][0]["native_trust"] == "builtin"
+    assert payload["matches"][0]["authority_class"] == "official_public"
+    assert payload["matches"][0]["official"] is True
+    assert payload["matches"][0]["enabled"] is True
+
+    external = tmp_path / "external"
+    collision = external / "duplicate"
+    collision.mkdir(parents=True)
+    (collision / "SKILL.md").write_text("---\nname: one-three-one-rule\n---\n", encoding="utf-8")
+    import agent.skill_utils as skill_utils
+    monkeypatch.setattr(skill_utils, "get_external_skills_dirs", lambda: [external])
+    with pytest.raises(SystemExit):
+        do_list(as_json=True, identifier_filter=IDENTIFIER)
+    collided = _payload(capsys)
+    assert collided["error"] == "canonical_ambiguity"
+    assert any(value.startswith("duplicate_name:one-three-one-rule:") for value in collided["ambiguities"])
+
+
+def test_canonical_rejects_duplicate_lock_keys(profile_home, capsys):
+    lock_path = profile_home / "skills" / ".hub" / "lock.json"
+    lock_path.parent.mkdir(parents=True)
+    entry = json.dumps({
+        "source": "official",
+        "identifier": IDENTIFIER,
+        "trust_level": "builtin",
+        "install_path": "communication/one-three-one-rule",
+    })
+    lock_path.write_text(
+        '{"version":1,"installed":{"one-three-one-rule":'
+        + entry + ',"one-three-one-rule":' + entry + '}}',
+        encoding="utf-8",
+    )
+    with pytest.raises(SystemExit):
+        do_list(as_json=True, identifier_filter=IDENTIFIER)
+    payload = _payload(capsys)
+    assert payload["error"] == "canonical_ambiguity"
+    assert "duplicate_lock_key:one-three-one-rule" in payload["ambiguities"]
+
+
